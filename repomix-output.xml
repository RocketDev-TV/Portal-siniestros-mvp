import type { ReactNode } from 'react';

interface MetricCardProps {
  label: string;
  value: number | string;
  icon: ReactNode;
  accent: 'indigo' | 'green' | 'red' | 'amber' | 'slate';
}

const ACCENT_STYLES: Record<MetricCardProps['accent'], string> = {
  indigo: 'bg-indigo-50 text-indigo-600',
